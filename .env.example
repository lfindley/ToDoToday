# Frontend env (Vite). Copy to `.env` to enable cross-device sync.
# Point this at your running backend (see server/SETUP.md). If unset, the app
# defaults to http://localhost:8787. Leaving sync unused keeps the app local-only.
VITE_API_URL=http://localhost:8787

# Show the account / sign-in UI. Hidden unless set to "true" — keep it off for a
# frontend-only (local-only) deploy where no backend is running. Set to "true"
# once the backend is deployed (and VITE_API_URL points at it) to enable accounts.
VITE_ENABLE_ACCOUNTS=false
