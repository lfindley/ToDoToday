# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Postgres connection string. Create a free project at https://neon.tech and
# paste its connection string here (it already includes ?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign JWT access tokens. Use a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-string"

# 32-byte key (base64) for AES-256-GCM encryption of stored calendar credentials.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="change-me-32-byte-base64-key"

# Port the API listens on.
PORT=8787

# Allowed CORS origin (the frontend). Comma-separate to allow several.
CORS_ORIGIN="http://localhost:5173"
